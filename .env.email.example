# Email Configuration Settings for PanelMerge Application
# Copy these settings to your .env file

# ============================================================================
# EMAIL SERVER CONFIGURATION
# ============================================================================

# SMTP Server Settings
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False

# Email Credentials (IMPORTANT: Use App Password for Gmail)
# For Gmail: Enable 2FA, then create App Password at:
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here

# Sender Configuration
MAIL_DEFAULT_SENDER=noreply@panelmerge.com
MAIL_MAX_EMAILS=50

# ============================================================================
# DEVELOPMENT MODE
# ============================================================================

# Set to False in production to actually send emails
# Set to True in development to suppress sending (logs to console instead)
MAIL_SUPPRESS_SEND=True

# ============================================================================
# TOKEN EXPIRATION SETTINGS
# ============================================================================

# Email verification token validity (in seconds)
# Default: 86400 seconds = 24 hours
VERIFICATION_TOKEN_MAX_AGE=86400

# Password reset token validity (in seconds)
# Default: 3600 seconds = 1 hour
PASSWORD_RESET_TOKEN_MAX_AGE=3600

# ============================================================================
# ALTERNATIVE SMTP PROVIDERS
# ============================================================================

# SendGrid Configuration (Uncomment to use)
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key

# Amazon SES Configuration (Uncomment to use)
# MAIL_SERVER=email-smtp.us-east-1.amazonaws.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-ses-access-key-id
# MAIL_PASSWORD=your-ses-secret-access-key

# Mailgun Configuration (Uncomment to use)
# MAIL_SERVER=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=postmaster@your-domain.mailgun.org
# MAIL_PASSWORD=your-mailgun-password

# Office 365 Configuration (Uncomment to use)
# MAIL_SERVER=smtp.office365.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@yourdomain.com
# MAIL_PASSWORD=your-password

# ============================================================================
# NOTES
# ============================================================================

# Gmail Setup Instructions:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and your device
# 4. Copy the 16-character password
# 5. Use this password in MAIL_PASSWORD above

# Production Recommendations:
# - Use a dedicated transactional email service (SendGrid, SES, etc.)
# - Set MAIL_SUPPRESS_SEND=False
# - Use environment-specific sender addresses
# - Monitor email delivery rates
# - Set up SPF, DKIM, and DMARC records for your domain

# Security Best Practices:
# - Never commit .env file to version control
# - Rotate credentials regularly
# - Use different credentials for dev/staging/production
# - Monitor for unauthorized access
# - Use strong, unique passwords
